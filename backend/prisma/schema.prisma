generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────

enum EmploymentStatus {
  EMPLOYED
  SELF_EMPLOYED
  UNEMPLOYED
  STUDENT
  RETIRED
}

enum CreditScore {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum ProductCategory {
  BALANCE_TRANSFER
  CREDIT_BUILDER
  CASHBACK
  REWARDS
  PURCHASE_0PC
  TRAVEL
  LOW_APR
}

enum AdminRole {
  SUPER_ADMIN
  EDITOR
}

enum LeadStatus {
  NEW
  SOLD
  CONTACTED
  CONVERTED
  DISMISSED
}

// ── Models ──────────────────────────────────────────────────────

model Lead {
  id                String            @id @default(uuid())
  createdAt         DateTime          @default(now())

  // Personal info (optional except email)
  name              String?
  email             String
  phone             String?

  // Quiz answers (used for matching)
  employment        EmploymentStatus
  annualIncome      Int               // GBP
  creditHistory     CreditScore
  hasDebt           Boolean
  missedPayments    Boolean

  // GDPR consent — MUST be true to monetize
  consentToShare    Boolean           // Agrees to share with partners
  consentMarketing  Boolean           @default(false)

  // Tracking
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?

  // Sales pipeline
  status            LeadStatus        @default(NEW)
  brokerNotes       String            @default("")
  matchedProducts   String[]          @default([]) // Product IDs that matched
  score             Int               @default(0)  // Match score 0-100

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model Product {
  id                String            @id @default(uuid())
  name              String
  slug              String            @unique
  logoUrl           String            @default("")
  description       String            @default("")
  shortDescription  String            @default("")

  // Financial data
  apr               Float             // Representative APR
  creditLimitMin    Int               @default(200)
  creditLimitMax    Int               @default(5000)
  representativeExample String        @default("")

  // Matching criteria
  minIncome         Int               @default(12000)
  minCreditScore    CreditScore       @default(POOR)
  requiresEmployment Boolean          @default(false)
  excludedEmployment EmploymentStatus[] @default([])

  // Monetization
  affiliateLink     String            @default("")
  brokerPayout      Float             @default(20.0) // £ per lead
  category          ProductCategory

  // Display
  features          String[]          @default([])
  pros              String[]          @default([])
  cons              String[]          @default([])
  isFeatured        Boolean           @default(false)
  isActive          Boolean           @default(true)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([slug])
  @@index([category])
  @@index([isActive])
}

model Partner {
  id                String            @id @default(uuid())
  name              String            @unique
  email             String
  phone             String            @default("")
  company           String            @default("")
  payoutPerLead     Float             @default(20.0)
  isActive          Boolean           @default(true)
  notes             String            @default("")
  createdAt         DateTime          @default(now())
  leadsSold         Int               @default(0)

  @@index([isActive])
}

model Article {
  id                String            @id @default(uuid())
  title             String
  slug              String            @unique
  excerpt           String            @default("")
  content           String            // Markdown or HTML
  category          String            @default("guide")
  targetKeyword     String            @default("")
  metaTitle         String            @default("")
  metaDescription   String            @default("")
  isPublished       Boolean           @default(false)
  publishedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@index([category])
}

model Admin {
  id                String            @id @default(uuid())
  email             String            @unique
  passwordHash      String
  role              AdminRole         @default(EDITOR)
  createdAt         DateTime          @default(now())
}

model LeadExport {
  id                String            @id @default(uuid())
  createdAt         DateTime          @default(now())
  leadIds           String[]          // Array of lead IDs exported
  partnerId         String?
  format            String            @default("csv") // csv, json
  exportedBy        String            @default("admin")

  @@index([createdAt])
}
